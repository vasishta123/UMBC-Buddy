# UMBC Buddy Chatbot Environment Configuration
# Copy this file to .env and fill in the required values

# API Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
ENV=development

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Google Dialogflow Configuration
DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id
DIALOGFLOW_SESSION_ID=your-session-id
DIALOGFLOW_CREDENTIALS_JSON_PATH=path/to/dialogflow-credentials.json

# Slack Bot Configuration (Optional)
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# File Paths
PDF_PATH=data/UMBC_International.pdf
DATA_DIR=data/
MODELS_DIR=models/

# Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4-turbo
TEMPERATURE=0.7
MAX_TOKENS=500

# Vector Database Configuration
VECTOR_DB_TYPE=faiss
VECTOR_DB_PATH=data/vectordb
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/umbc_buddy.log

# Response Configuration
CONFIDENCE_THRESHOLD=0.5
MAX_SOURCES=3

# Cache Configuration
ENABLE_CACHING=True
CACHE_TTL=3600

# Rate Limiting
ENABLE_RATE_LIMITING=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
